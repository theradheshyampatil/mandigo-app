{
  "name": "mandigo-backend-api",
  "version": "0.1.0",
  "private": true,
  "description": "MandiGo - B2B Fruit Marketplace API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
