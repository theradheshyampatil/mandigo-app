# Keep the Docker build context lean.
# Anything listed here will NOT be sent to the Docker daemon.

# Node
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist
build
.vite
.cache

# VCS / CI
.git
.gitignore
.github

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Env files (build-time VITE_* vars should be passed as Docker build args, not baked in)
.env
.env.*
!.env.production

# Docs / misc (we already include Dockerfile via implicit context)
README.md
*.md
